{
  "name": "gh-sweep",
  "version": "1.0.5",
  "description": "Interactive CLI to review and clean up your GitHub repos",
  "repository": {
    "type": "git",
    "url": "https://github.com/scottrobertson/gh-sweep.git"
  },
  "type": "module",
  "bin": {
    "gh-sweep": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "tsup && node dist/index.js",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome check --write"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
